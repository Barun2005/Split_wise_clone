generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  email        String               @unique
  passwordHash String
  name         String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  groupsCreated Group[]             @relation("GroupCreator")
  memberships   GroupMember[]
  expensesPaid  Expense[]           @relation("ExpensePayer")
  expensesOwed  ExpenseParticipant[]
  settlementsPaid Settlement[]      @relation("SettlementPayer")
  settlementsReceived Settlement[]  @relation("SettlementReceiver")
}

model Group {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  createdById String         @db.ObjectId
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy   User           @relation("GroupCreator", fields: [createdById], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  imports     ImportSession[]
}

model GroupMember {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  groupId   String    @db.ObjectId
  userId    String    @db.ObjectId
  joinDate  DateTime  @default(now())
  leaveDate DateTime? // Null means still active

  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Expense {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  groupId     String    @db.ObjectId
  title       String
  amount      Float
  currency    String    @default("INR")
  date        DateTime
  paidById    String    @db.ObjectId
  splitType   SplitType @default(EQUAL)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy      User      @relation("ExpensePayer", fields: [paidById], references: [id])
  participants ExpenseParticipant[]
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

model ExpenseParticipant {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  expenseId       String  @db.ObjectId
  userId          String  @db.ObjectId
  amountOwed      Float
  splitPercentage Float?
  exactAmount     Float?

  expense         Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId   String   @db.ObjectId
  paidById  String   @db.ObjectId
  paidToId  String   @db.ObjectId
  amount    Float
  currency  String   @default("INR")
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy    User     @relation("SettlementPayer", fields: [paidById], references: [id])
  paidTo    User     @relation("SettlementReceiver", fields: [paidToId], references: [id])
}

model ImportSession {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId      String   @db.ObjectId
  uploadedById String   @db.ObjectId
  status       ImportStatus @default(PENDING)
  totalRows    Int      @default(0)
  importedRows Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  issues       ImportIssue[]
}

enum ImportStatus {
  PENDING
  REVIEW
  COMPLETED
  FAILED
}

model ImportIssue {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  importSessionId String   @db.ObjectId
  rowNumber       Int
  severity        IssueSeverity
  description     String
  suggestedFix    String?
  rawData         String   // JSON string of the raw row
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())

  session         ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
}

enum IssueSeverity {
  WARNING
  ERROR
}
